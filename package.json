{
  "name": "backend-simple-reserva",
  "version": "1.0.0",
  "description": "SimpleReserva REST API backend",
  "main": "src/index.js",
  "scripts": {
    "dev": "npx prisma generate && NODE_ENV=development nodemon src/index.js",
    "start": "node src/index.js",
    "build": "npx prisma generate",
    "migrate": "npx prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "db:deploy": "prisma migrate deploy && node prisma/seed.js",
    "postinstall": "npm run build",
    "test": "node --test src/**/*.test.js",
    "cy:seed": "node cypress/scripts/seed.js",
    "cy:run": "npx cypress run",
    "cy:open": "npx cypress open",
    "cy:test": "npm run cy:seed && npx cypress run",
    "cy:test:open": "npm run cy:seed && npx cypress open"
  },
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@prisma/client": "^6.17.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "mercadopago": "^2.0.12",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pino": "^9.14.0",
    "prisma": "^6.17.0",
    "qrcode": "^1.5.4",
    "resend": "^4.0.0",
    "speakeasy": "^2.0.0",
    "twilio": "^5.12.2",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "cypress": "^14.3.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
