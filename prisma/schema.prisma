generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String    @id @default(cuid())
  email                         String    @unique
  name                          String?
  lastName                      String?
  hashedPassword                String
  role                          String    // "super_admin" | "restaurant_owner" | "restaurant_manager" | "restaurant_host"
  country                       String    @default("CL") // "CL", "AR", "UY"
  lastLogin                     DateTime?
  twoFactorSecret               String?
  twoFactorEnabled              Boolean   @default(false)
  userEnabledTwoFactor          Boolean   @default(false)
  twoFactorRecoveryCode         String?
  twoFactorRecoveryCodeExpires  DateTime?
  passwordResetCode             String?
  passwordResetCodeExpires      DateTime?
  dashboardTourCompletedAt      DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  ownedOrganization             RestaurantOrganization? @relation("OrgOwner")
  managedOrganizations          OrganizationManager[]
  hostedOrganizations           OrganizationHost[]
  checkoutSessions              CheckoutSession[]
  offeredPlans                  CustomPlanOffer[]
  reservationsConfirmed         Reservation[] @relation("ReservationConfirmedBy")
  reservationsUpdated           Reservation[] @relation("ReservationUpdatedBy")
  
  @@index([role])
}

model RestaurantOrganization {
  id            String   @id @default(cuid())
  name          String
  ownerId       String?  @unique
  owner         User?    @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  
  planId        String
  plan          Plan @relation("OrgDefaultPlan", fields: [planId], references: [id])

  // Plan personalizado asignado por el admin. Si está seteado, se ofrece además de los planes públicos.
  // Permite tarifas, límites o condiciones especiales para un cliente específico.
  customPlanId  String?
  customPlan    Plan?    @relation("OrgCustomPlan", fields: [customPlanId], references: [id])
  
  trialEndsAt   DateTime?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurants   Restaurant[]
  managers      OrganizationManager[]
  hosts         OrganizationHost[]
  subscriptions Subscription[]
  reservationAnalytics ReservationAnalytics[]
  paymentReceipts PaymentReceipt[]
  checkoutSessions CheckoutSession[]
  customPlanOffers CustomPlanOffer[]

  // Billing fields
  billingType         String    @default("boleta")  // "boleta" | "factura"
  billingTaxId        String?   // RUT or tax ID
  billingBusinessName String?   // Company/business name
  billingAddress      String?
  billingEmail        String?   // Billing-specific email

  reservationNotifyScope        ReservationNotifyScope @default(restaurant)
  reservationNotifyAudience     ReservationNotifyAudience @default(owner)
  reservationNotifyCustomEmail  String?
  reservationNotifyRecipients   Json?
  reservationNotifyOnWeb        Boolean @default(true)
  reservationNotifyOnManual     Boolean @default(true)

  @@index([ownerId])
  @@index([customPlanId])
  @@index([isDeleted])
}

model OrganizationManager {
  id             String                 @id @default(cuid())
  organizationId String
  organization   RestaurantOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime               @default(now())

  restaurantAssignments ManagerRestaurantAssignment[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model ManagerRestaurantAssignment {
  id                    String              @id @default(cuid())
  organizationManagerId String
  organizationManager   OrganizationManager @relation(fields: [organizationManagerId], references: [id], onDelete: Cascade)
  restaurantId          String
  restaurant            Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt             DateTime            @default(now())

  @@unique([organizationManagerId, restaurantId])
  @@index([organizationManagerId])
  @@index([restaurantId])
}

model OrganizationHost {
  id             String                 @id @default(cuid())
  organizationId String
  organization   RestaurantOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime               @default(now())

  restaurantAssignments HostRestaurantAssignment[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model HostRestaurantAssignment {
  id                 String           @id @default(cuid())
  organizationHostId String
  organizationHost   OrganizationHost @relation(fields: [organizationHostId], references: [id], onDelete: Cascade)
  restaurantId       String
  restaurant         Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@unique([organizationHostId, restaurantId])
  @@index([organizationHostId])
  @@index([restaurantId])
}

enum BookingAcceptanceMode {
  ALWAYS_24_7
  DURING_OPERATIONAL
  CUSTOM
}

enum BookingClosedFallback {
  DISABLE
  MESSAGE
  CONTACT
}

enum ReservationNotifyAudience {
  owner
  managers
  hosts
  all
  custom
}

enum ReservationNotifyScope {
  organization
  restaurant
}

model Restaurant {
  id                        String    @id @default(cuid())
  organizationId            String
  organization              RestaurantOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug                      String    @unique
  name                      String
  description               String?
  logoUrl                   String?
  address                   String?
  shortAddress              String?
  googlePlaceId             String?
  latitude                  Float?
  longitude                 Float?
  phone                     String?
  email                     String?
  defaultSlotDurationMinutes Int      @default(60)
  slotIntervalMinutes        Int      @default(30)
  reservationEndPolicy       String   @default("STRICT_END") // "STRICT_END" | "ALLOW_OVERFLOW"
  reservationWindowMode      String   @default("same_as_schedule") // "same_as_schedule" | "custom"
  bufferMinutesBetweenReservations Int @default(0)
  advanceBookingLimitDays   Int      @default(30)
  minimumNoticeMinutes     Int      @default(60)
  noShowGracePeriodMinutes Int      @default(15)
  holdTtlSeconds             Int      @default(300)
  holdsEnabled               Boolean  @default(true)
  requireEmail              Boolean   @default(true)
  requirePhoneNumber        Boolean   @default(false)
  menuPdfUrl                String?
  timezone                  String?   // IANA timezone string, e.g. "America/Santiago". If null, resolved from owner's country.
  isActive                  Boolean   @default(true)
  isDeleted                 Boolean   @default(false)
  scheduleMode              String    @default("continuous") // "continuous" | "service_periods"
  appearanceTheme           String    @default("crema-calida") // booking page palette id
  bookingAcceptanceMode     BookingAcceptanceMode @default(ALWAYS_24_7)
  bookingClosedFallback     BookingClosedFallback @default(MESSAGE)
  bookingClosedMessage      String?
  bookingContactPhone       String?
  bookingContactWhatsapp    String?
  bookingContactEmail       String?
  dataVersion               Int       @default(0)
  onboardingCompletedAt     DateTime?
  reservationNotifyRecipients Json?
  reservationNotifyOnWeb      Boolean   @default(true)
  reservationNotifyOnManual   Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  zones                     Zone[]
  durationRules             DurationRule[]
  schedules                 Schedule[]
  reservationWindows        ReservationWindow[]
  bookingAcceptanceWindows  BookingAcceptanceWindow[]
  blockedSlots              BlockedSlot[]
  reservations              Reservation[]
  holds                     ReservationHold[]
  pacingRules               PacingRule[]
  menus                     RestaurantMenu[]
  managerAssignments        ManagerRestaurantAssignment[]
  hostAssignments           HostRestaurantAssignment[]
  reservationAnalytics      ReservationAnalytics[]
  waitlistEntries           BookingWaitlistEntry[]
  feedbackSurvey            FeedbackSurvey?
  feedbackRequests          FeedbackRequest[]
  feedbackAlerts            FeedbackAlert[]

  @@index([organizationId])
  @@index([isActive])
  @@index([isDeleted])
}

/// Lista de espera — cliente sin cupo deja datos para que el local contacte
model BookingWaitlistEntry {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  partySize      Int
  preferredDate  String?
  customerName   String
  customerPhone  String
  customerEmail  String?
  notes          String?
  status         String     @default("pending")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([restaurantId, createdAt])
}

model RestaurantMenu {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type         String   @default("pdf") // "pdf" | "link"
  label        String
  sortOrder    Int      @default(0)
  visible      Boolean  @default(true)
  menuType     String?  // legacy: "main" | "drinks" | "dessert"
  fileName     String?
  fileSize     Int?
  r2Key        String?
  url          String
  externalUrl  String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([restaurantId, sortOrder])
}

model DurationRule {
  id              String     @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  minPartySize    Int
  maxPartySize    Int
  durationMinutes Int
  createdAt       DateTime   @default(now())

  @@unique([restaurantId, minPartySize])
  @@index([restaurantId])
}

model Zone {
  id            String    @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  /// Tamaño del plano interactivo (celdas)
  gridCols      Int       @default(10)
  gridRows      Int       @default(10)
  smokingZone   Boolean   @default(false)
  petFriendly   Boolean   @default(false)

  tables        RestaurantTable[]

  @@index([restaurantId])
}

model RestaurantTable {
  id            String    @id @default(cuid())
  zoneId        String
  zone          Zone      @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  label         String
  minCapacity   Int       @default(1)
  maxCapacity   Int
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  /// Origen en grilla del plano (celda superior izquierda), null = sin posición en plano
  posX          Int?
  posY          Int?
  rotation      Int       @default(0) // 0, 90, 180, 270
  shape         String    @default("square") // square | rectangular | round
  width         Int       @default(1) // ancho en celdas
  height        Int       @default(1) // alto en celdas

  reservations  Reservation[]
  holds         ReservationHold[]

  @@index([zoneId])
}

model Schedule {
  id                  String    @id @default(cuid())
  restaurantId        String
  restaurant          Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dayOfWeek           Int       // 0=Sunday, 1=Monday, ..., 6=Saturday
  openTime            String    // "09:00"
  closeTime           String    // "22:00"
  closesNextDay       Boolean   @default(false)
  isActive            Boolean   @default(true)
  breakfastStartTime  String?   // service_periods mode
  breakfastEndTime    String?
  lunchStartTime      String?
  lunchEndTime        String?
  dinnerStartTime     String?
  dinnerEndTime       String?
  dinnerEndsNextDay   Boolean   @default(false)

  @@unique([restaurantId, dayOfWeek])
}

model BookingAcceptanceWindow {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dayOfWeek    Int        // 0=Sunday … 6=Saturday
  startTime    String     // "15:00"
  endTime      String     // "18:00"
  endsNextDay  Boolean    @default(false)
  isActive     Boolean    @default(true)

  @@index([restaurantId, dayOfWeek])
}

model ReservationWindow {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dayOfWeek    Int        // 0=Sunday … 6=Saturday
  startTime    String     // "15:00"
  endTime      String     // "19:00"
  endsNextDay  Boolean    @default(false)
  label        String?
  sortOrder    Int        @default(0)

  @@index([restaurantId, dayOfWeek])
}

/// Regla de pacing por intervalo — tope opcional de comensales o reservas por cupo.
/// Si no hay reglas, la disponibilidad solo depende de mesas libres (comportamiento default).
model PacingRule {
  id                     String     @id @default(cuid())
  restaurantId           String
  restaurant             Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dayOfWeek              Int?       // null = aplica a todos los días
  maxCoversPerSlot       Int?       // tope de personas totales por intervalo
  maxReservationsPerSlot Int?       // tope de reservas totales por intervalo
  createdAt              DateTime   @default(now())

  @@index([restaurantId])
}

/// Hold temporal de slot — reserva preventiva durante el checkout (TTL configurable por restaurante).
/// Una reserva = una mesa; el hold bloquea esa mesa hasta que se confirme o expire.
model ReservationHold {
  id              String          @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId         String
  table           RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  partySize       Int
  dateTime        DateTime        // inicio del slot en UTC
  durationMinutes Int             // duración calculada al crear el hold
  expiresAt       DateTime        // createdAt + holdTtlSeconds
  holdToken       String          @unique @default(cuid())
  sessionId       String?         // fingerprint anónimo del comensal (cookie)
  source          String          @default("web") // "web" | "staff" | "api"
  status          String          @default("active") // "active" | "consumed" | "released" | "expired"
  createdAt       DateTime        @default(now())

  @@index([restaurantId, dateTime, status])
  @@index([expiresAt, status])
  @@index([holdToken])
}

model BlockedSlot {
  id            String    @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  startDatetime DateTime
  endDatetime   DateTime
  reason        String?

  @@index([restaurantId, startDatetime, endDatetime])
}

model Reservation {
  id              String    @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId         String?
  table           RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerName    String
  customerPhone   String?
  customerEmail   String?
  emailSent       Boolean   @default(false)
  partySize       Int
  dateTime        DateTime
  businessDate    DateTime? @db.Date
  durationMinutes Int
  status          String    @default("confirmed") // "confirmed", "cancelled", "completed", "no_show"
  source          String    @default("web")      // "web" (public booking), "manual" (admin panel), "phone"
  notes           String?
  secureToken     String    @unique @default(cuid())
  confirmedByUserId String?
  confirmedByUser   User?     @relation("ReservationConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  updatedByUserId   String?
  updatedByUser     User?     @relation("ReservationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  feedbackRequest           FeedbackRequest?

  @@index([restaurantId, dateTime, status])
  @@index([restaurantId, businessDate, status])
  @@index([secureToken])
  @@index([confirmedByUserId])
  @@index([updatedByUserId])
}

/// Configuración de encuesta post-visita por restaurante (1:1)
model FeedbackSurvey {
  id                              String     @id @default(cuid())
  restaurantId                    String     @unique
  restaurant                      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  enabled                         Boolean    @default(false)
  sendDelayMinutes                Int        @default(60)
  sendWindowMinutes               Int        @default(240)
  minDaysBetweenFeedbackRequests  Int        @default(14)
  eligibilityMode                 String     @default("confirmed_past_end") // "confirmed_past_end" | "completed_only"
  excludeWalkIns                  Boolean    @default(true)
  minPartySize                    Int?
  maxPartySize                    Int?
  googleReviewUrl                 String?
  instagramUrl                    String?
  recoveryThreshold               Int        @default(2)
  notifyOnRecovery                Boolean    @default(true)
  notifyEmail                     String?
  brandingJson                    Json?
  createdAt                       DateTime   @default(now())
  updatedAt                       DateTime   @updatedAt
}

/// Un envío de encuesta por reserva (idempotente)
model FeedbackRequest {
  id                      String     @id @default(cuid())
  reservationId           String     @unique
  reservation             Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  restaurantId            String
  restaurant              Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  token                   String     @unique @default(cuid())
  channel                 String     @default("email")
  customerEmailNormalized String?
  scheduledFor            DateTime
  sentAt                  DateTime?
  clickedAt               DateTime?
  openedAt                DateTime?
  completedAt             DateTime?
  status                  String     @default("pending") // pending | sent | clicked | opened | completed | expired | skipped
  skipReason              String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  response                FeedbackResponse?

  @@index([status, scheduledFor])
  @@index([restaurantId, customerEmailNormalized, sentAt])
}

/// Respuesta del comensal
model FeedbackResponse {
  id                         String          @id @default(cuid())
  feedbackRequestId        String          @unique
  feedbackRequest            FeedbackRequest @relation(fields: [feedbackRequestId], references: [id], onDelete: Cascade)
  overallScore               Int
  serviceScore               Int?
  foodScore                  Int?
  atmosphereScore            Int?
  reservationScore           Int?
  comment                    String?
  sentiment                  String?
  recoveryTriggered          Boolean         @default(false)
  recoveryContactRequested   Boolean         @default(false)
  recoveryContactEmail       String?
  recoveryContactPhone       String?
  tags                       String[]        @default([])
  partySize                  Int?
  dateTime                   DateTime?
  dayOfWeek                  Int?
  hourBucket                 Int?
  tableId                    String?
  zoneId                     String?
  organizationId             String?
  cityKey                    String?
  respondedAt                DateTime        @default(now())

  alerts                     FeedbackAlert[]
}

/// Alertas de recovery e insights operacionales
model FeedbackAlert {
  id                 String            @id @default(cuid())
  restaurantId       String
  restaurant         Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  feedbackResponseId String?
  feedbackResponse   FeedbackResponse? @relation(fields: [feedbackResponseId], references: [id], onDelete: SetNull)
  type               String            @default("recovery") // recovery | extreme_negative | pattern
  severity           String            @default("medium") // low | medium | high
  severitySource     String?           // score | comment | both
  matchedKeywords    String[]          @default([])
  title              String
  body               String
  status                 String            @default("open") // open | acknowledged | resolved
  resolvedAt             DateTime?
  resolvedByUserId       String?
  resolvedByDisplayName  String?
  resolutionNote         String?
  createdAt              DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([restaurantId, status])
}

/// Opt-out de encuestas por email (hash)
model CustomerFeedbackPreference {
  id           String     @id @default(cuid())
  emailHash    String
  restaurantId String?
  optedOutAt   DateTime   @default(now())

  @@unique([emailHash, restaurantId])
  @@index([emailHash])
}

model Subscription {
  id            String    @id @default(cuid())
  organizationId String
  organization  RestaurantOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId        String
  plan          Plan @relation(fields: [planId], references: [id])
  status        String    @default("trial") // "trial", "active", "grace", "cancelled", "cancelled_by_admin", "expired", "scheduled" — informational only
  /// Single source of truth for feature access. Set to false only by expiry jobs (gracePeriodExpiryJob, trialExpiryJob).
  isActiveSubscription Boolean @default(true)
  startDate     DateTime  @default(now())
  endDate       DateTime?
  /// Fin del periodo de facturación actual (persistido al activar/renovar; alineado con computePeriodEnd)
  currentPeriodEnd DateTime?
  /// Access deadline: 7 days after payment failure, OR set equal to endDate on manual cancellation
  gracePeriodEndsAt DateTime?
  mercadopagoPreapprovalId String?   // MercadoPago subscription id when paid
  createdAt     DateTime  @default(now())

  paymentReceipts PaymentReceipt[]

  @@unique([organizationId, mercadopagoPreapprovalId])
  @@index([organizationId])
  @@index([currentPeriodEnd])
  @@index([isActiveSubscription])
}

model EmailDomain {
  id        String    @id @default(cuid())
  domain    String    @unique
  createdAt DateTime  @default(now())
  senders   EmailSender[]
}

model EmailSender {
  id        String    @id @default(cuid())
  email     String    @unique
  domainId  String?
  domain    EmailDomain? @relation(fields: [domainId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model Configuration {
  id                    String    @id @default(cuid())
  twoFactorEnabled      Boolean   @default(false)
  appName               String    @default("SimpleReserva")
  recoveryEmailSenderId String?
  reservationEmailSenderId String?
  dashboardPollingIntervalSeconds Int @default(30)
  updatedAt             DateTime  @updatedAt

  // WhatsApp Business Cloud API (Meta) — optional; env vars are fallback
  whatsappAuthToken              String?
  whatsappSendingPhoneNumberId   String?
  whatsappBusinessAccountId      String?
  whatsappApiVersion             String?   @default("v21.0")
  whatsappTemplateLanguage       String?   @default("es")
}

model WhatsAppTemplate {
  id             String    @id @default(cuid())
  metaId         String?   @unique
  name           String
  language       String    @default("es")
  category       String?
  status         String?
  bodyText       String?
  componentsJson Json?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([name, language])
  @@index([status])
}

// Plan configuration - super admin editable, single source of truth for plan features/limits/pricing
model Plan {
  id                       String   @id @default(cuid())
  productSKU               String   @unique
  name                     String
  description              String?
  type                     String   @default("restaurant")
  isDefault                Boolean  @default(true)

  maxRestaurants           Int
  maxZonesPerRestaurant    Int?
  maxTables                Int?
  maxTeamMembers           Int?

  whatsappFeatures         Boolean  @default(true)
  googleReserveIntegration Boolean  @default(false)
  multipleMenu             Boolean  @default(false)
  prioritySupport          Boolean  @default(false)
  postVisitFeedback        Boolean  @default(false)

  comingSoon               Boolean  @default(false)
  comingSoonLabel          String?

  priceCLP                 Decimal  @default(0) @db.Decimal(10,2)
  priceUSD                 Decimal  @default(0) @db.Decimal(10,2)
  priceEUR                 Decimal  @default(0) @db.Decimal(10,2)

  billingFrequency         Int      @default(1)
  billingFrequencyType     String   @default("months")

  freeTrialLength          Int      @default(0)
  freeTrialLengthUnit      String   @default("months")
  
  mercadopagoPreapprovalPlanId  String?   @unique
  mercadopagoInitPoint          String?
  mercadopagoLastSyncAt         DateTime?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organizations            RestaurantOrganization[]  @relation("OrgDefaultPlan")
  customOrganizations      RestaurantOrganization[]  @relation("OrgCustomPlan")
  subscriptions            Subscription[]
  paymentReceipts          PaymentReceipt[]
  checkoutSessions         CheckoutSession[]
  promoCodes               PromoCode[]               @relation("PromoCodePlan")
  offers                   CustomPlanOffer[]
}

// Booking analytics events - tracking user behavior on the booking page
model BookingEvent {
  id           String   @id @default(cuid())
  sessionId    String
  restaurantId String
  eventName    String
  stepName     String?
  properties   Json?
  deviceType   String?
  userAgent    String?
  timestamp    DateTime @default(now())

  @@index([restaurantId, eventName, timestamp])
  @@index([sessionId])
  @@index([timestamp])
}

// Marketing / landing analytics — public site CTAs and funnel
model MarketingEvent {
  id         String   @id @default(cuid())
  sessionId  String
  pagePath   String
  eventName  String
  ctaId      String?
  properties Json?
  deviceType String?
  userAgent  String?
  timestamp  DateTime @default(now())

  @@index([pagePath, eventName, timestamp])
  @@index([sessionId])
  @@index([ctaId, timestamp])
  @@index([timestamp])
}

/// Contadores diarios de reservas. Índices únicos parciales (fecha+restaurante y fecha agregado global)
/// viven en la migración `20260515162000_reservation_analytics_partial_unique` para soportar ON CONFLICT en SQL raw.
model ReservationAnalytics {
  id               String                  @id @default(cuid())
  date             DateTime                @db.Date
  restaurantId     String?
  restaurant       Restaurant?             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  organizationId   String?
  organization     RestaurantOrganization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reservationCount Int                     @default(0)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([date])
  @@index([restaurantId, date])
  @@index([organizationId, date])
}

model PaymentReceipt {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          RestaurantOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionId        String?
  subscription          Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  planId                String
  plan                  Plan @relation(fields: [planId], references: [id])

  amount                Decimal   @db.Decimal(10,2)
  currency              String    // "CLP", "USD", "EUR"
  paymentDate           DateTime

  receiptType           String    // "boleta" | "factura"

  clientName            String?
  clientEmail           String?
  clientTaxId           String?   // RUT (Chile) or equivalent
  clientBusinessName    String?   // Company name, relevant for "factura"
  clientAddress         String?

  mercadopagoPaymentId  String?   @unique
  mercadopagoStatus     String?   // "approved", "pending", etc.

  legalReceiptSent      Boolean   @default(false)
  legalReceiptSentAt    DateTime?
  legalReceiptSentBy    String?   // admin user ID who marked it

  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([organizationId])
  @@index([legalReceiptSent])
  @@index([paymentDate])
  @@index([receiptType])
}

model CheckoutSession {
  id                        String    @id @default(cuid())
  organizationId            String
  organization              RestaurantOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                    String
  plan                      Plan @relation(fields: [planId], references: [id])

  status                    String    @default("pending") // "pending" | "completed" | "expired" | "abandoned"
  mercadopagoPreapprovalId  String?
  checkoutUrl               String?
  /// Si existe, al autorizar el nuevo preapproval se cancela esta suscripción en MP (cambio de plan inmediato sin perder acceso antes de pagar).
  pendingChangeFromSubscriptionId String?

  createdAt                 DateTime  @default(now())
  expiresAt                 DateTime?
  completedAt               DateTime?

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([pendingChangeFromSubscriptionId])
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  type            String    @default("signup_plan_grant") // future: "discount", "extend_trial", etc.

  // What this code grants (for type=signup_plan_grant)
  planId          String?
  plan            Plan?     @relation("PromoCodePlan", fields: [planId], references: [id])
  durationValue   Int?      // e.g. 3
  durationUnit    String?   // "days" | "months"

  // Redemption rules
  maxRedemptions  Int?      // null => unlimited (still gated by isActive/expiresAt)
  timesRedeemed   Int       @default(0)
  lockedToEmail   String?   // optional pin to a single email (case-insensitive match)

  // Lifecycle
  isActive        Boolean   @default(true)
  expiresAt       DateTime? // code itself stops working after this date

  notes           String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  redemptions     PromoCodeRedemption[]

  @@index([type])
  @@index([isActive])
  @@index([planId])
}

model PromoCodeRedemption {
  id               String    @id @default(cuid())
  promoCodeId      String
  promoCode        PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId           String
  organizationId   String
  redeemedAt       DateTime  @default(now())
  planAccessEndsAt DateTime? // mirror of trialEndsAt at redemption time, for audit

  @@index([promoCodeId])
  @@index([userId])
  @@index([organizationId])
}

/// Planes personalizados ofrecidos a organizaciones específicas.
/// Permite que el admin ofrezca un plan no público a una o más organizaciones,
/// y que esas organizaciones lo vean en su página de facturación.
model CustomPlanOffer {
  id             String                 @id @default(cuid())
  planId         String
  plan           Plan                   @relation(fields: [planId], references: [id], onDelete: Cascade)
  organizationId String
  organization   RestaurantOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  offeredById    String?
  offeredBy      User?                  @relation(fields: [offeredById], references: [id], onDelete: SetNull)
  createdAt      DateTime               @default(now())

  @@unique([planId, organizationId])
  @@index([organizationId])
  @@index([planId])
}

/// Registro persistente de cada evento webhook recibido desde MercadoPago.
/// Garantiza idempotencia (unique mpEventType+mpDataId) y permite debugging retroactivo.
model WebhookEvent {
  id               String    @id @default(cuid())
  mpEventType      String    // "subscription_preapproval" | "payment" | etc.
  mpDataId         String    // data.id del payload MP
  mpStatus         String?   // estado real consultado a MP API tras recibir el evento
  organizationId   String?   // extraído de external_reference (nullable si no se puede parsear)
  externalRef      String?   // external_reference completo del preapproval/payment
  processingStatus String    @default("received") // "received" | "processed" | "failed" | "skipped"
  errorMessage     String?   // mensaje de error truncado si processingStatus = "failed"
  rawHeaders       Json?     // metadata de headers: x-request-id, presencia de x-signature
  processedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@unique([mpEventType, mpDataId])
  @@index([organizationId])
  @@index([createdAt])
  @@index([processingStatus])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  restaurantId String?
  action       String
  resourceType String?
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([restaurantId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}
