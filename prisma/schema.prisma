generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String    @id @default(cuid())
  email                         String    @unique
  name                          String?
  lastName                      String?
  hashedPassword                String
  role                          String    // "super_admin" (system-wide) or "owner"/"admin" (legacy, use UserRestaurant for restaurant access)
  lastLogin                     DateTime?
  twoFactorSecret               String?
  twoFactorEnabled              Boolean   @default(false)
  userEnabledTwoFactor          Boolean   @default(false)
  twoFactorRecoveryCode         String?
  twoFactorRecoveryCodeExpires  DateTime?
  passwordResetCode             String?
  passwordResetCodeExpires      DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  userRestaurants               UserRestaurant[]
  planOverride                  PlanOverride?

  @@index([role])
}

model UserRestaurant {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  role         String   // "owner" | "admin"
  createdAt    DateTime @default(now())

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
}

model Restaurant {
  id                        String    @id @default(cuid())
  slug                      String    @unique
  name                      String
  description               String?
  logoUrl                   String?
  address                   String?
  phone                     String?
  email                     String?
  defaultSlotDurationMinutes Int      @default(60)
  bufferMinutesBetweenReservations Int @default(0)
  advanceBookingLimitDays   Int      @default(30)
  minimumNoticeMinutes     Int      @default(60)
  noShowGracePeriodMinutes Int      @default(15)
  menuPdfUrl                String?
  isActive                  Boolean   @default(true)
  trialEndsAt               DateTime? // null = legacy/no trial; set = trial ends at this date (14 days from signup or inherited)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  userRestaurants           UserRestaurant[]
  zones                     Zone[]
  schedules                 Schedule[]
  blockedSlots              BlockedSlot[]
  reservations              Reservation[]
  subscriptions             Subscription[]

  @@index([isActive])
}

model Zone {
  id            String    @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  tables        RestaurantTable[]

  @@index([restaurantId])
}

model RestaurantTable {
  id            String    @id @default(cuid())
  zoneId        String
  zone          Zone      @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  label         String
  minCapacity   Int       @default(1)
  maxCapacity   Int
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  reservations  Reservation[]

  @@index([zoneId])
}

model Schedule {
  id            String    @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dayOfWeek     Int       // 0=Sunday, 1=Monday, ..., 6=Saturday
  openTime      String    // "09:00"
  closeTime     String    // "22:00"
  breakStartTime String?  // "15:00" - start of gap (e.g. between lunch and dinner)
  breakEndTime   String?  // "19:00" - end of gap
  isActive      Boolean   @default(true)

  @@unique([restaurantId, dayOfWeek])
}

model BlockedSlot {
  id            String    @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  startDatetime DateTime
  endDatetime   DateTime
  reason        String?

  @@index([restaurantId, startDatetime, endDatetime])
}

model Reservation {
  id              String    @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId         String?
  table           RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerName    String
  customerPhone   String
  customerEmail   String?
  partySize       Int
  dateTime        DateTime
  durationMinutes Int
  status          String    @default("confirmed") // "confirmed", "cancelled", "completed", "no_show"
  source          String    @default("web")      // "web" (public booking), "manual" (admin panel), "phone"
  notes           String?
  secureToken     String    @unique @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([restaurantId, dateTime, status])
  @@index([secureToken])
}

model Subscription {
  id            String    @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  plan          String    @default("profesional") // "basico" | "profesional" | "premium"
  status        String    @default("trial") // "trial", "active", "grace", "cancelled", "expired"
  startDate     DateTime  @default(now())
  endDate       DateTime?
  gracePeriodEndsAt DateTime? // 7-day grace after payment failure; access until this date
  mercadopagoPreapprovalId String?   // MercadoPago subscription id when paid
  createdAt     DateTime  @default(now())

  @@index([restaurantId])
}

model EmailSender {
  id        String    @id @default(cuid())
  email     String    @unique
  createdAt DateTime  @default(now())
}

model Configuration {
  id                    String    @id @default(cuid())
  twoFactorEnabled      Boolean   @default(false)
  appName               String    @default("SimpleReserva")
  recoveryEmailSenderId String?
  updatedAt             DateTime  @updatedAt
}

// Plan configuration - super admin editable, single source of truth for plan features/limits/pricing
model PlanConfig {
  id     String @id @default(cuid())
  plan   String @unique // "basico" | "profesional" | "premium"

  // Feature flags (boolean)
  smsConfirmations         Boolean @default(true)
  smsReminders             Boolean @default(true)
  whatsappConfirmations     Boolean @default(true)
  whatsappReminders         Boolean @default(true)
  whatsappModificationAlerts Boolean @default(true)
  menuPdf                   Boolean @default(false)
  advancedBookingSettings   Boolean @default(false)
  brandingRemoval           Boolean @default(false)
  analyticsWeekly           Boolean @default(false)
  analyticsMonthly          Boolean @default(false)
  crossLocationDashboard    Boolean @default(false)
  prioritySupport           Boolean @default(false)

  // Numeric limits (null = unlimited)
  maxLocations    Int
  maxZones        Int?    // null = unlimited
  maxTables       Int?    // null = unlimited
  maxTeamMembers  Int?    // null = unlimited

  // Pricing (flat per plan, not per location)
  biweeklyPriceCLP     Int    @default(0)
  currency             String @default("CLP")
  billingFrequencyDays Int    @default(14)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-owner overrides for price, features, and limits (super admin editable)
model PlanOverride {
  id        String   @id @default(cuid())
  userId    String   @unique // owner's User id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Price override (null = use plan default)
  biweeklyPriceCLP Int?

  // Feature overrides (null = use plan default)
  menuPdf                 Boolean?
  advancedBookingSettings Boolean?
  brandingRemoval         Boolean?
  analyticsWeekly         Boolean?
  analyticsMonthly        Boolean?
  crossLocationDashboard  Boolean?
  prioritySupport         Boolean?

  // Limit overrides (null = use plan default)
  maxLocations   Int?
  maxZones       Int?
  maxTables      Int?
  maxTeamMembers Int?

  expiresAt  DateTime? // when null, override never expires
  reason     String?   // audit: why this override was applied
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
}
