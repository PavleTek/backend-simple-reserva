# -----------------------------------------------------------------------------
# Copy to .env and fill in real values. Never commit .env.
# -----------------------------------------------------------------------------

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/simplereserva?schema=public"

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Server & CORS — optional. Leave unset or empty to allow any browser origin.
# If set, only listed origins (plus localhost:any-port in non-production) are allowed.
PORT=3000
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
# Con API vía ngrok, el front envía el header ngrok-skip-browser-warning; el backend ya lo permite en CORS.

# Resend (transactional email) — https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# App branding (e.g. emails)
APP_NAME=SimpleReserva

# Public URLs
# - BACKEND_PUBLIC_URL: public base for webhooks (MercadoPago notification_url) and API links
# - FRONTEND_RESTAURANT_PORTAL_URL: MercadoPago back_url after checkout (must be set in production)
# - FRONTEND_LADNING_PAGE_URL: matches env var name used in code (marketing / booking site)
BACKEND_PUBLIC_URL=https://involucral-noninferentially-rocio.ngrok-free.dev
FRONTEND_LADNING_PAGE_URL=http://localhost:5173
FRONTEND_RESTAURANT_PORTAL_URL=http://localhost:5175
FRONTEND_ADMIN_PORTAL_URL=http://localhost:5174

# Cloudflare R2 (S3-compatible — menu images, etc.)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=simplereserva-menus
R2_PUBLIC_URL=https://your-r2-public-url.example

# MercadoPago — https://www.mercadopago.cl/developers
# Prueba (Chile) — misma aplicación en el panel; credenciales TEST empiezan por TEST-
MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxxxxxx
# (Opcional) MERCADOPAGO_TEST_MODE=true
# Con MERCADOPAGO_ACCESS_TOKEN que empiece por TEST-: obligatorio usar el comprador de prueba:
# MP_TEST_PAYER_EMAIL=test_user_xxxxx@testuser.com  # campo "Usuario" del Comprador (Cuentas de prueba, Chile)
# MP_WEBHOOK_SECRET=...   # desde Webhooks en el panel
# MERCADOPAGO_LOG_SELLER=false        # opcional: si está en false, no se llama GET /users/me antes del checkout
# Si MP responde "Cannot operate between different countries": el Access Token debe ser de una app
# creada en mercadopago.cl (site_id MLC). No mezclar credenciales de developers de otro país con CLP.

# -----------------------------------------------------------------------------
# Optional / advanced (uncomment as needed)
# -----------------------------------------------------------------------------
# If MercadoPago rejects localhost back_url, use a public tunnel to the restaurant Vite port:
# FRONTEND_RESTAURANT_PORTAL_PUBLIC_URL=https://your-tunnel.example

# Test accounts & webhooks:
# MERCADOPAGO_TEST_MODE=true
# MP_TEST_PAYER_EMAIL=test_user_xxxxx@testuser.com
# MP_WEBHOOK_SECRET=

# WhatsApp Business Cloud API (Meta) — fallback if not stored in admin panel / DB
# See docs/WHATSAPP_MESSAGE_TEMPLATES.md
# WHATSAPP_AUTH_TOKEN=your_permanent_or_temporary_access_token
# WHATSAPP_SENDING_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_TEMPLATE_LANGUAGE=es
# Verbose WhatsApp logs to stdout ([WhatsApp] / [Notification]); set to false to reduce noise once stable
# WHATSAPP_VERBOSE_LOG=false

# Twilio (SMS only — optional)
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_PHONE_NUMBER=+56xxxxxxxxx

# BOOKING_BASE_URL=https://your-domain.example
# REMINDER_CRON=0 10 * * *
# RECONCILIATION_CRON=0 */6 * * *

# -----------------------------------------------------------------------------
# Checklist E2E para testing con cuentas de prueba MP
# -----------------------------------------------------------------------------
# 1. Crear cuentas de prueba en https://www.mercadopago.cl/developers/panel/app
#    (una vendedor TEST, una comprador TEST)
# 2. Usar el Access Token del VENDEDOR de prueba en MERCADOPAGO_ACCESS_TOKEN
# 3. Exponer el backend con ngrok: BACKEND_PUBLIC_URL=https://xxxx.ngrok.io
# 4. Registrar la URL de webhook en el panel MP:
#    https://xxxx.ngrok.io/api/webhooks/mercadopago
# 5. Configurar MP_WEBHOOK_SECRET desde el panel de webhooks MP
# 6. Registrar un restaurante → verificar trial activo
# 7. Ir a /billing → hacer checkout con plan Profesional
# 8. Pagar con tarjeta de prueba: 5031 7557 3453 0604 CVV 123
# 9. Verificar retorno a /billing?returnFromCheckout=1 (back_url correcto)
# 10. Verificar WebhookEvent en DB con processingStatus=processed
# 11. Verificar PaymentReceipt creado
# 12. Cancelar → verificar sub cancelled, acceso hasta endDate
# 13. Cambiar plan → verificar flujo change-plan completo
# 14. Simular payment_required → verificar grace period 7 días
