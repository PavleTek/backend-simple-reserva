DATABASE_URL=postgresql://user:password@localhost:5432/simplereserva
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
PORT=3000
RESEND_API_KEY=re_your_resend_api_key
APP_NAME=SimpleReserva
# Frontend URL (para back_url de MercadoPago en producción)
APP_URL=http://localhost:5174
# URL pública del backend (ngrok) para pruebas locales cuando APP_URL es localhost
# BACKEND_PUBLIC_URL=https://xxxx.ngrok-free.app

# MercadoPago (required for billing/checkout - create app at https://www.mercadopago.cl/developers)
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx
#
# PRUEBAS: No uses TEST-xxx de la app. Para evitar "una de las partes es de prueba":
# 1. Crea Vendedor + Comprador de prueba (Chile) en Cuentas de prueba
# 2. Inicia sesión en mercadopago.cl con el Vendedor de prueba
# 3. Tu negocio > Configuración > Integraciones > Credenciales de producción
# 4. Usa el Access Token del Vendedor de prueba (suele ser APP_USR-xxx, no TEST-xxx)
# 5. Modo prueba: MERCADOPAGO_TEST_MODE=true (obligatorio cuando usas cuentas de prueba)
# 6. Usuario del Comprador (test_user_xxx@testuser.com) - copia exacta del campo en Cuentas de prueba
# MERCADOPAGO_TEST_MODE=true
# MP_TEST_PAYER_EMAIL=test_user_xxxxx@testuser.com
# MP_WEBHOOK_SECRET= (de Webhooks > Configurar para validar firma)

# Twilio SMS and WhatsApp (optional - for reservation confirmations, reminders, modification alerts)
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_PHONE_NUMBER=+56xxxxxxxxx
# TWILIO_WHATSAPP_FROM=+14155238886  # WhatsApp-enabled number (e.g. Twilio sandbox or production)

# Booking page base URL (for confirmation links in SMS)
# BOOKING_BASE_URL=https://simplereserva.com

# Reminder job cron (default: 10:00 Chile time daily)
# REMINDER_CRON=0 10 * * *

# Cloudflare R2 setup (S3-compatible)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=simplereserva-menus
R2_PUBLIC_URL=https://menus.simplereserva.com
