{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "npm install && npx prisma generate"
  },
  "deploy": {
    "preDeployCommand": [
      "npx prisma migrate deploy",
      "node prisma/seed.js"
    ],
    "startCommand": "npx prisma migrate deploy && node src/index.js"
  }
}
